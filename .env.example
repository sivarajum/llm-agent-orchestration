# --- LLM Provider ---
# Set one of these API keys to enable LLM-enhanced mode.
# Without a key the system runs in offline/fallback mode.
OPENAI_API_KEY=your_key_here
# OR
ANTHROPIC_API_KEY=your_key_here

# Explicit provider selection: "openai", "anthropic", or "" (auto-detect)
LLM_PROVIDER=

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
UI_PORT=8501

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# --- Logging ---
LOG_LEVEL=INFO

# --- Pipeline ---
MAX_ITERATIONS=3
APPROVAL_THRESHOLD=7
SEARCH_MAX_RESULTS=5
